{
  "name": "node_auth-app",
  "version": "1.0.0",
  "description": "Auth app",
  "main": "src/index.ts",
  "scripts": {
    "init": "mate-scripts init",
    "prebuild": "npm run prisma:generate:db",
    "build": "tsc",
    "start": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit --watch",
    "lint": "npm run format && mate-scripts lint",
    "format": "prettier --ignore-path .prettierignore --write './src/**/*.{js,ts}'",
    "pretest:only": "npm run prisma:generate:db",
    "test:only": "vitest run",
    "test:watch": "vitest",
    "update": "mate-scripts update",
    "postinstall": "npm run update && npm run prisma:generate:db",
    "test": "npm run lint && npm run test:only",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:stop": "docker compose stop",
    "db:logs": "docker compose logs -f db",
    "db:reset": "docker compose down -v",
    "prisma:pull": "prisma db pull",
    "prisma:add:db": "npx prisma dev",
    "prisma:generate:db": "npx prisma generate",
    "prisma:migrate:db": "prisma migrate dev",
    "client:dev": "npm --prefix src/client run dev",
    "client:build": "npm --prefix src/client run build",
    "client:test": "npm --prefix src/client run test"
  },
  "author": "Mate academy",
  "license": "GPL-3.0",
  "devDependencies": {
    "@mate-academy/eslint-config": "latest",
    "@mate-academy/scripts": "^2.1.3",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^8.0.0",
    "eslint": "^8.57.0",
    "eslint-plugin-node": "^11.1.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.3.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "mateAcademy": {
    "projectType": "typescript"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.7.0",
    "@reduxjs/toolkit": "^2.11.2",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^8.0.5",
    "pg": "^8.20.0",
    "pg-hstore": "^2.3.4",
    "prisma": "7.7.0",
    "uuid": "^14.0.0"
  }
}
